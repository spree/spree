# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# Rails
SECRET_KEY_BASE=generate_with_rails_secret
RAILS_ENV=production

# Spree
SPREE_PATH=/spree
CDN_HOST=https://example.com

# Redis (optional, auto-configured in docker-compose)
REDIS_URL=redis://redis:6379/1

# Database URL (auto-configured in docker-compose)
DATABASE_URL=postgresql://postgres:password@postgres:5432/spree_production

# Sidekiq
SIDEKIQ_CONCURRENCY=5

# API Keys & Secrets
RAILS_MASTER_KEY=your_master_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# R2 / Active Storage (if using S3-compatible storage)
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=your_bucket
AWS_REGION=us-west-1

# Email (if transactional emails enabled)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mail@example.com
SMTP_PASSWORD=password

# Custom Domain (if not using *.vercel.app)
STOREFRONT_URL=https://sklepik.example.com
ADMIN_DASHBOARD_URL=https://admin.example.com
