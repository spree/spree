<% if products.any? %>
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 w-10"></th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-600"><%= Spree.t(:product) %></th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-600"><%= Spree.t(:variants) %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% products.each do |product| %>
          <tr>
            <td class="px-4 py-2">
              <div class="custom-control form-checkbox">
                <%= check_box_tag "ids[]", product.id, false,
                    class: "custom-control-input",
                    id: "product_#{product.id}_checkbox",
                    data: { media_form_target: "checkbox", action: "media-form#showDeleteButton" } %>
                <label class="custom-control-label" for="product_<%= product.id %>_checkbox"><span></span></label>
              </div>
            </td>
            <td class="px-4 py-2">
              <%= link_to spree.edit_admin_product_path(product), data: { turbo_frame: '_top' }, class: "flex items-center text-gray-900 hover-none" do %>
                <%= render 'spree/admin/shared/product_image', object: product %>
                <span class="ml-4 text-sm"><%= product.name %></span>
              <% end %>
            </td>
            <td class="px-4 py-2 text-sm text-gray-500"><%= product.variants_including_master.count %></td>
          </tr>
        <% end %>
        <% if products_count > 20 %>
          <tr>
            <td colspan="3" class="px-4 py-2 text-sm text-gray-500 text-center">
              <%= Spree.t(:and_n_more, count: products_count - 20) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="p-8 text-center text-gray-500">
    <p><%= Spree.t(:no_products_in_price_list) %></p>
  </div>
<% end %>
