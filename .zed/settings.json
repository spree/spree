{
  "formatter": {
    "language_server": { "name": "biome" }
  },
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["biome", "vtsls", "!typescript-language-server", "!eslint"]
    },
    "TSX": {
      "language_servers": ["biome", "vtsls", "!typescript-language-server", "!eslint"]
    },
    "JavaScript": {
      "language_servers": ["biome", "vtsls", "!typescript-language-server", "!eslint"]
    }
  }
}
