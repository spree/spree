<%= render 'spree/shared/purchased_items_styles' %>

<table class="hero" width="100%" cellpadding="0" cellspacing="0" role="presentation">
  <tr>
    <td align="center">
      <div class="hero_content f-fallback">
        <h1><%= Spree.t('reimbursement_mailer.reimbursement_email.subject') %></h1>
        <p class="greeting"><%= Spree.t('reimbursement_mailer.reimbursement_email.dear_customer', name: name_for(@order)) %></p>
        <p><%= Spree.t('reimbursement_mailer.reimbursement_email.instructions') %></p>
      </div>
    </td>
  </tr>
</table>

<table class="section" width="100%" cellpadding="0" cellspacing="0" role="presentation">
  <tr>
    <td>
      <h3 class="f-fallback"><%= Spree.t('reimbursement_mailer.reimbursement_email.refund_summary') %></h3>
      <p class="strong f-fallback"><%= Spree.t('reimbursement_mailer.reimbursement_email.total_refunded', total: @reimbursement.display_total) %></p>
    </td>
  </tr>
</table>

<% if @reimbursement.return_items.exchange_requested.present? %>
  <table class="section" width="100%" cellpadding="0" cellspacing="0" role="presentation">
    <tr>
      <td>
        <h3 class="f-fallback"><%= Spree.t('reimbursement_mailer.reimbursement_email.exchange_summary') %></h3>
        <% @reimbursement.return_items.exchange_requested.each do |return_item| %>
          <% product_url = spree_storefront_resource_url(return_item.variant.product) %>
          <table class="item" width="100%" cellpadding="0" cellspacing="0" role="presentation">
            <tr>
              <td class="item_image" width="96" valign="middle">
                <% image = return_item.variant.primary_media || return_item.variant.product.primary_media %>
                <% if image.present? && image.attached? %>
                  <%= link_to spree_image_tag(image, variant: :small, alt: return_item.variant.name, width: 80, class: 'item_thumb'), product_url %>
                <% else %>
                  <%= link_to image_tag('noimage/small.png', alt: return_item.variant.name, width: 80, class: 'item_thumb'), product_url %>
                <% end %>
              </td>
              <td class="item_info" valign="middle">
                <%= link_to return_item.variant.name, product_url, class: 'f-fallback item_name' %>
                <% if return_item.exchange_variant.options_text.present? %>
                  <p class="item_meta"><%= return_item.exchange_variant.options_text %></p>
                <% end %>
              </td>
            </tr>
          </table>
        <% end %>
        <% if @reimbursement.return_items.awaiting_return.present? && Spree::Config[:expedited_exchanges] %>
          <p class="sub f-fallback"><%= Spree.t('reimbursement_mailer.reimbursement_email.days_to_send', days: Spree::Config[:expedited_exchanges_days_window]) %></p>
        <% end %>
      </td>
    </tr>
  </table>
<% end %>

<table class="signoff" width="100%" cellpadding="0" cellspacing="0" role="presentation">
  <tr>
    <td align="center">
      <p class="f-fallback">
        <%= Spree.t('reimbursement_mailer.reimbursement_email.thanks') %>
        <br />
        <%= Spree.t('reimbursement_mailer.reimbursement_email.store_team', store_name: current_store.name) %>
      </p>
    </td>
  </tr>
</table>
