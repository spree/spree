<div class="card mb-6">
  <div class="card-header">
    <h5 class="card-title">
      <%= Spree.t(:tracking_url) %>
    </h5>
  </div>
  <div class="card-body">
    <div class="form-group">
      <%= f.url_field :tracking_url, class: 'form-input', placeholder: Spree.t(:tracking_url_placeholder) %>
      <%= f.error_message_on :tracking_url %>
    </div>

    <p class="form-text small mt-2">
      <code>:tracking</code>
      <span><%= Spree.t('admin.shipping_methods.tracking_url_token_help') %></span>
    </p>
  </div>
</div>