<% conversion_url = supported_currencies.length > 1 && can?(:manage, Spree::Price) ? spree.admin_currency_conversions_path : nil %>
<div class="card mb-6"
     data-product-form-target="pricesForm"
     <% if conversion_url %>
       data-controller="currency-prices"
       data-currency-prices-url-value="<%= conversion_url %>"
       data-currency-prices-locale-value="<%= I18n.locale %>"
     <% end %>>
  <div class="card-header flex items-center justify-between border-b-0">
    <h5 class="card-title">
      <%= Spree.t(:pricing) %>
    </h5>

    <% if can?(:manage, Spree::Store) %>
      <%= link_to_with_icon 'world', Spree.t('admin.manage_markets'), spree.admin_markets_path, class: 'btn btn-sm btn-light' %>
    <% end %>
  </div>
  <div class="card-body p-0">
    <% if conversion_url %>
      <p class="form-text px-4 pt-3 mb-0"><%= Spree.t('admin.currency_prices.auto_convert_hint') %></p>
    <% end %>
    <table class="table border-t">
      <thead>
        <tr>
          <th scope="col"><%= Spree.t(:currency) %></th>
          <th scope="col">
            <%= Spree.t(:amount) %>
          </th>
          <th scope="col">
            <%= Spree.t(:compare_at_amount) %>
            <%= help_bubble(Spree.t('admin.variants_form.compare_at_price_description')) %>
          </th>
        </tr>
      </thead>
      <tbody <% if conversion_url %>data-action="input->currency-prices#scheduleConvert"<% end %>>
        <% base_prices = f.object.prices.select { |p| p.price_list_id.nil? } %>
        <%= f.fields_for :prices, base_prices do |price_form| %>
          <%= price_form.hidden_field :id if price_form.object.persisted? %>
          <%= price_form.hidden_field :currency %>
          <tr>
            <td><%= price_form.object.currency %></td>
            <td>
              <%= price_form.spree_money_field :amount,
                                               disabled: !can?(:manage, price_form.object),
                                               currency: price_form.object.currency,
                                               label: false %>
            </td>
            <td>
              <%= price_form.spree_money_field :compare_at_amount,
                                               disabled: !can?(:manage, price_form.object),
                                               currency: price_form.object.currency,
                                               label: false %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
