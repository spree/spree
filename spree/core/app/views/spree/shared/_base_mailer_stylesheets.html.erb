<style type="text/css" rel="stylesheet" media="all">
  /* Fonts ------------------------------ */
  /* Same files the react-email Studio templates load; Gmail strips these and falls back to Arial. */

  @font-face {
    font-family: "Geist";
    font-style: normal;
    font-weight: 500;
    src: url("https://fonts.gstatic.com/s/geist/v4/gyByhwUxId8gMEwcGFU.woff2") format("woff2");
  }

  @font-face {
    font-family: "Geist";
    font-style: normal;
    font-weight: 600;
    src: url("https://fonts.gstatic.com/s/geist/v4/gyByhwUxId8gMEwcGFU.woff2") format("woff2");
  }

  @font-face {
    font-family: "Geist";
    font-style: normal;
    font-weight: 700;
    src: url("https://fonts.gstatic.com/s/geist/v4/gyByhwUxId8gMEwcGFU.woff2") format("woff2");
  }

  @font-face {
    font-family: "Inter";
    font-style: normal;
    font-weight: 400;
    src: url("https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuOKfMZg.ttf") format("truetype");
  }

  @font-face {
    font-family: "Inter";
    font-style: normal;
    font-weight: 450;
    src: url("https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuOKfMZg.ttf") format("truetype");
  }

  @font-face {
    font-family: "Inter";
    font-style: normal;
    font-weight: 500;
    src: url("https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuI6fMZg.ttf") format("truetype");
  }

  @font-face {
    font-family: "Inter";
    font-style: normal;
    font-weight: 600;
    src: url("https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuGKYMZg.ttf") format("truetype");
  }

  /* Base ------------------------------ */

  body {
    width: 100% !important;
    height: 100%;
    margin: 0;
    -webkit-text-size-adjust: none;
    background-color: #FFFFFF;
    color: #726A6A;
  }

  a {
    color: #332C2C;
  }

  a img {
    border: none;
  }

  td {
    word-break: break-word;
  }

  .preheader {
    display: none !important;
    visibility: hidden;
    mso-hide: all;
    font-size: 1px;
    line-height: 1px;
    max-height: 0;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
  }

  /* Type ------------------------------ */

  body,
  td,
  th {
    font-family: "Inter", Helvetica, Arial, sans-serif;
  }

  h1 {
    margin: 0 0 24px;
    font-family: "Geist", "Inter", Helvetica, Arial, sans-serif;
    color: #332C2C;
    font-size: 40px;
    line-height: 1.2;
    letter-spacing: -0.8px;
    font-weight: 700;
    text-align: center;
  }

  h2 {
    margin: 0 0 16px;
    font-family: "Geist", "Inter", Helvetica, Arial, sans-serif;
    color: #332C2C;
    font-size: 22px;
    line-height: 1.4;
    letter-spacing: -0.18px;
    font-weight: 500;
    text-align: center;
  }

  h3 {
    margin: 0 0 16px;
    font-family: "Geist", "Inter", Helvetica, Arial, sans-serif;
    color: #A2A9AA;
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.16px;
    font-weight: 500;
    text-align: left;
  }

  td,
  th {
    font-size: 14px;
  }

  p,
  ul,
  ol,
  blockquote {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.6;
    letter-spacing: -0.042px;
    font-weight: 450;
    color: #726A6A;
  }

  p.sub {
    font-size: 13px;
    color: #A2A9AA;
  }

  p.sub a {
    color: #726A6A;
    word-break: break-all;
  }

  p.strong {
    margin: 0;
    font-weight: 500;
    color: #332C2C;
  }

  /* Utilities ------------------------------ */

  .align-right {
    text-align: right;
  }

  .align-left {
    text-align: left;
  }

  .align-center {
    text-align: center;
  }

  /* Buttons ------------------------------ */

  .button {
    display: inline-block;
    background-color: #FFFFFF;
    border: 1px solid #E8E9E9;
    border-radius: 8px;
    padding: 12px 20px;
    font-size: 15px;
    line-height: 1.6;
    font-weight: 500;
    color: #1F2222 !important;
    text-decoration: none;
    -webkit-text-size-adjust: none;
    box-sizing: border-box;
  }

  .button--green {
    background-color: #22BC66;
    border-color: #22BC66;
    color: #FFFFFF !important;
  }

  .button--red {
    background-color: #FF6136;
    border-color: #FF6136;
    color: #FFFFFF !important;
  }

  @media only screen and (max-width: 500px) {
    .button {
      width: 100% !important;
      text-align: center !important;
    }
  }

  /* Hero ------------------------------ */

  .hero {
    width: 100%;
    text-align: center;
  }

  .hero_content {
    max-width: 420px;
    margin: 0 auto;
  }

  .hero h1 {
    margin: 0;
  }

  .hero p {
    margin: 12px 0 0;
  }

  .hero .greeting {
    margin: 24px 0 0;
    font-size: 15px;
    font-weight: 500;
    color: #332C2C;
  }

  .hero .sub {
    margin: 24px 0 0;
  }

  .hero .sub + .sub {
    margin: 16px 0 0;
  }

  /* Sections ------------------------------ */

  .section {
    width: 100%;
    margin: 48px 0 0;
    text-align: left;
  }

  .section .sub {
    margin: 16px 0 0;
  }

  /* Structure ------------------------------ */

  .email-wrapper {
    width: 100%;
    margin: 0;
    padding: 0;
    background-color: #FFFFFF;
  }

  .email-content {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 0;
  }

  /* Masthead ----------------------- */

  .email-masthead {
    padding: 0 0 32px;
    text-align: center;
  }

  .email-masthead_name {
    font-size: 16px;
    font-weight: 600;
    color: #332C2C;
    text-decoration: none;
  }

  /* Body ------------------------------ */

  .email-card {
    background-color: #F6F6F6;
    padding: 56px 24px;
  }

  .email-footer {
    padding: 64px 24px;
    text-align: center;
  }

  .email-footer p {
    color: #726A6A;
  }

  .footer_content {
    max-width: 320px;
    margin: 0 auto;
  }

  .footer_brand {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    letter-spacing: -0.13px;
  }

  .footer_brand a {
    color: #726A6A;
    font-weight: 500;
    text-decoration: none;
  }

  .footer_meta {
    margin: 12px 0 0;
    font-size: 11px;
    line-height: 1.5;
    letter-spacing: -0.11px;
  }

  .footer_meta a {
    color: #726A6A;
  }

  .footer_note {
    margin: 20px 0 0;
    font-size: 11px;
    line-height: 1.5;
    letter-spacing: -0.11px;
    color: #A2A9AA;
  }

  .body-action {
    width: 100%;
    margin: 32px auto 0;
    padding: 0;
    text-align: center;
  }

  .body-sub {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #F0F0F0;
  }

  /* Data table (legacy class hooks) ------------------------------ */

  .purchase,
  .purchase_content {
    width: 100%;
    margin: 0;
  }

  .purchase_item {
    padding: 10px 4px;
    color: #726A6A;
    font-size: 14px;
    line-height: 1.6;
  }

  .purchase_item--additional {
    font-size: 13px;
    color: #A2A9AA;
  }

  .purchase_total {
    margin: 0;
    text-align: right;
    font-weight: 500;
    color: #332C2C;
  }

  .purchase_total--name {
    margin: 0;
    text-align: right;
    color: #726A6A;
  }

  /* Media Queries ------------------------------ */

  @media only screen and (max-width: 600px) {
    .email-card {
      padding: 40px 16px !important;
    }
    .email-footer {
      padding: 48px 16px !important;
    }
    h1 {
      font-size: 32px !important;
      letter-spacing: -0.64px !important;
    }
  }
</style>
