{
  "name": "create-spree-app",
  "version": "1.2.0",
  "description": "Create a new Spree Commerce project with a single command",
  "type": "module",
  "bin": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --fix src tests",
    "format": "biome format --write src tests",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "spree",
    "commerce",
    "ecommerce",
    "scaffold",
    "create",
    "cli",
    "docker",
    "nextjs",
    "typescript",
    "headless"
  ],
  "author": "Vendo Connect Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spree/spree.git",
    "directory": "packages/create-spree-app"
  },
  "homepage": "https://spreecommerce.org",
  "bugs": {
    "url": "https://github.com/spree/spree/issues"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "get-port": "^7.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
