# Dev-server proxy target — where Vite forwards /api and /rails (your Rails
# backend). The SPA stays same-origin with the API: the SDK uses relative
# URLs and the proxy bridges the port gap.
#
# Do NOT set VITE_SPREE_API_URL for local dev — it switches the SDK to
# absolute cross-origin URLs, which breaks on CORS and the SameSite=Lax auth
# cookie. Set it only when building for a deploy where the dashboard is
# hosted on a different origin than the API.
#
# No credentials belong in this file — every VITE_-prefixed value is
# compiled into the client bundle.
VITE_API_PROXY_TARGET=http://localhost:3000
