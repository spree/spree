{
  "name": "@spree/dashboard-ui",
  "private": true,
  "license": "MIT",
  "version": "0.0.0",
  "description": "Spree Dashboard design system — shadcn primitives, composed components, and design tokens. Source-only package; consumers compile via their own Vite/Tailwind setup.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --fix src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "~6.0.3"
  }
}
